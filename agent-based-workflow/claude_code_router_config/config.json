{
  "NON_INTERACTIVE_MODE": true,
  "APIKEY": "dummy",
  "LOG_LEVEL": "trace",
  "Providers": [
    {
      "name": "openrouter",
      "api_base_url": "https://openrouter.ai/api/v1/chat/completions",
      "api_key": "$OPENROUTER_API_KEY",
      "models": [
        "qwen/qwen3-coder"
      ],
      "transformer": {
        "use": ["openrouter"],
        "qwen/qwen3-coder": {
          "use": [
            [
              "openrouter",
              {
                "provider": {
                  "ignore": ["deepinfra", "gmicloud", "siliconflow","google-vertex"]
                }
              }
            ]
          ]
        }
      }
    }
  ],
  "Router": {
    "default": "openrouter,qwen/qwen3-coder"
  }
}