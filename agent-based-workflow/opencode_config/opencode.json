{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "openrouter/qwen/qwen3-coder",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true
      },
      "temperature": 0.0
    }
  },
  "provider": {
    "openrouter": {
      "models": {
        "qwen/qwen3-coder": {
          "options": {
            "provider": {
              "ignore": ["deepinfra", "gmicloud", "siliconflow","google-vertex"]
            }
          }
        }
      }
    }
  }
}
